<menu id="system-menu" label="Openbox">

  <item label="Openbox Configuration Manager">
    <action name="Execute">
      <command>obconf</command>
      <startupnotify><enabled>yes</enabled></startupnotify>
    </action>
  </item>

  <item label="Edit menu.xml">
    <action name="Execute">
	    <command>gvim /home/shin/.config/openbox/menu.xml</command>
      <startupnotify>
        <enabled>no</enabled>
      </startupnotify>
    </action>
  </item>

  <item label="Edit rc.xml">
    <action name="Execute">
	    <command>gvim /home/shin/.config/openbox/rc.xml</command>
      <startupnotify>
        <enabled>no</enabled>
      </startupnotify>
    </action>
  </item>

  <item label="Edit themerc">
    <action name="Execute">
	    <command>gvim /usr/share/themes/Distantfire/openbox-3/themerc</command>
      <startupnotify>
        <enabled>no</enabled>
      </startupnotify>
    </action>
  </item>

  <item label="Edit autostart">
    <action name="Execute">
	    <command>gvim /home/shin/.config/openbox/autostart</command>
      <startupnotify>
        <enabled>no</enabled>
      </startupnotify>
    </action>
  </item>

  <separator />

  <item label="Reconfigure Openbox">
    <action name="Reconfigure" />
  </item>

</menu>

