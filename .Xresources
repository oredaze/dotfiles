XTerm*termName:        xterm-256color
XTerm*VT100.geometry:  95x40
XTerm*vt100.utf8:      true
XTerm*cursorBlink:     true
XTerm*visualBell:      false
XTerm*scrollTtyOutput: false
XTerm*locale:          true
XTerm*metaSendsEscape: true
XTerm*eightBitInput:   true
XTerm*saveLines:       1024
XTerm*toolBar:         false

Xft.dpi:       92
Xft.rgba:      none
Xft.hinting:   true
Xft.hintstyle: hintslight
Xft.antialias: 1

rofi.modi:                 run,window
rofi.combi-modi:           window,run
rofi.color-enabled:        true
rofi.font:                 droopybdf 9
rofi.separator-style:      dash
rofi.bw:                   1
rofi.line-margin:          0
rofi.hide-scrollbar:       true
rofi.fake-transparency:    false
rofi.opacity:              90
rofi.yoffset:              0
rofi.location:             0
rofi.width:                20
rofi.lines:                13
rofi.columns:              1
rofi.fixed-num-lines:      true
rofi.padding:              5
rofi.show-icons:           false
rofi.terminal:             urxvt
rofi.cycle:                false
rofi.matching:             normal
rofi.max-history-size:     10
rofi.kb-move-word-back:    Control+Left,Alt+Left
rofi.kb-move-word-forward: Control+Right,Alt+Right
rofi.kb-remove-word-back:  Control+BackSpace,Alt+BackSpace

URxvt.depth:             32
URxvt.cursorBlink:       false
URxvt.letterSpace:       0
URxvt.geometry:          88x44
URxvt.skipBuiltinGlyphs: true
URxvt.scrollBar:         false
!URxvt.scrollstyle:      plain
!URxvt.scrollBar_right:  true
URxvt.troughColor:       #1F1F1F
URxvt.scrollTtyOutput:   false
URxvt.scrollTtyKeypress: true
URxvt.secondaryScroll:   true
URxvt.saveLines:         4096
URxvt.perl-ext:
URxvt.perl-ext-common:
URxvt.iso14755:          false
URxvt.iso14755_52:       false

URxvt.keysym.Control-Up:        \033[1;5A
URxvt.keysym.Control-Down:      \033[1;5B
URxvt.keysym.Control-Left:      \033[1;5D
URxvt.keysym.Control-Right:     \033[1;5C
URxvt.keysym.Control-BackSpace: \033[1;H
URxvt.keysym.S-Up:              command:\033]720;3\007
URxvt.keysym.S-Down:            command:\033]721;3\007

URxvt*font: -hacker-droopybdf-medium-*-*-*-12-*-*-*-*-*-*-*, \
		-*-fixed-*-*-*-*-14-*-*-*-*-*-jisx0208.1983-*
URxvt*boldFont: -hacker-droopybdf-bold-*-*-*-12-*-*-*-*-*-*-*, \
		-*-fixed-*-*-*-*-14-*-*-*-*-*-jisx0208.1983-*
URxvt*italicFont: -hacker-droopybdf-medium-*-*-*-12-*-*-*-*-*-*-*, \
		-*-fixed-*-*-*-*-14-*-*-*-*-*-jisx0208.1983-*
URxvt*boldItalicFont: -hacker-droopybdf-bold-*-*-*-12-*-*-*-*-*-*-*, \
		-*-fixed-*-*-*-*-14-*-*-*-*-*-jisx0208.1983-*

!URxvt*font: xft:droopy:Medium:autohint=false:size=12, \
!		xft:mplus:Medium:autohint=false:size=12
!URxvt*boldFont: xft:droopy:Bold:autohint=false:bold:size=12, \
!		xft:mplus:Bold:autohint=false:size=12
!URxvt*italicFont: xft:droopy:Medium:autohint=false:size=12, \
!		xft:mplus:Medium:autohint=false:size=12
!URxvt*boldItalicFont: xft:droopy:Bold:autohint=false:bold:size=12, \
!		xft:mplus:Bold:autohint=false:size=12

#include ".cache/wal/colors.Xresources"
